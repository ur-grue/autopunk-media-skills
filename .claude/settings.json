{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Repo-local hook registration for autopunk-media-skills development. Consumers of the skill library do NOT inherit these hooks — they install them explicitly via scripts/install-hooks.sh.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/ai-slop-detector.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/archive-reminder.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/ai-slop-detector.sh" }
        ]
      }
    ]
  }
}
